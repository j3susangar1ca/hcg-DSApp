<Window
    x:Class="GestionDocumental.Presentation.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HCG - Gestión Documental">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" Padding="20" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel Spacing="15">
                <TextBlock Text="Procesamiento IA" FontSize="20" FontWeight="Bold"/>
                
                <InfoBar x:Name="FaseInfoBar" Title="Fase Actual" Message="Nacimiento" IsOpen="True" Severity="Informational" />

                <Button x:Name="BtnCargar" Content="Seleccionar PDF" HorizontalAlignment="Stretch" Height="45"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="Datos Extraídos (IA)" Foreground="Gray" FontSize="12"/>
                    <Border BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" Padding="10" CornerRadius="4">
                        <StackPanel Spacing="10">
                            <TextBox Header="Remitente" Text="{x:Bind ViewModel.Remitente, Mode=OneWay}" IsReadOnly="True"/>
                            <TextBox Header="Asunto" Text="{x:Bind ViewModel.Asunto, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"/>
                            <CheckBox Content="Es Urgente" IsChecked="{x:Bind ViewModel.IsUrgente, Mode=OneWay}" IsEnabled="False"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Button x:Name="BtnIA" Content="Clasificar con IA" HorizontalAlignment="Stretch" Height="45" IsEnabled="False" Style="{StaticResource AccentButtonStyle}"/>
                <Button x:Name="BtnArchivar" Content="Archivar en Red" HorizontalAlignment="Stretch" Height="45" IsEnabled="False"/>
                
                <TextBlock x:Name="StatusText" Text="{x:Bind ViewModel.MensajeEstado, Mode=OneWay}" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" Background="DarkGray">
            <WebView2 x:Name="PdfViewer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            <TextBlock x:Name="PlaceholderText" Text="Cargue un documento para visualizarlo" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="16"/>
        </Grid>
    </Grid>
</Window>