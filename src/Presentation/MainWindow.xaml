<Window
    x:Class="GestionDocumental.Presentation.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HCG - Sistema de Gestión">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Padding="20" Spacing="10">
            <TextBlock Text="Panel de Control" FontSize="18" FontWeight="Bold"/>
            <Button x:Name="BtnCargar" Content="1. Cargar PDF" HorizontalAlignment="Stretch"/>
            <Button x:Name="BtnIA" Content="2. Clasificar" HorizontalAlignment="Stretch" IsEnabled="False"/>
            <Button x:Name="BtnArchivar" Content="3. Guardar" HorizontalAlignment="Stretch" IsEnabled="False"/>
            <TextBlock x:Name="StatusText" Text="Listo" Foreground="Gray" Margin="0,10"/>
        </StackPanel>

        <Grid Grid.Column="1" Background="Silver">
            <WebView2 x:Name="PdfViewer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>