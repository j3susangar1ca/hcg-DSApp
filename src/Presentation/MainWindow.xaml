<Window
    x:Class="GestionDocumental.Presentation.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HCG - Gestión Documental">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="10" Grid.Row="0">
            <TextBlock Text="Gestión de Documentos CADIDO" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Estado del Proceso" Foreground="Gray"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="20">
            <InfoBar Title="Fase Actual" Message="Nacimiento" IsOpen="True" Severity="Informational" x:Name="FaseInfoBar"/>
            
            <Button Content="1. Cargar PDF" HorizontalAlignment="Stretch" Padding="15" x:Name="BtnCargar"/>
            <Button Content="2. Clasificar con IA" HorizontalAlignment="Stretch" Padding="15" IsEnabled="False" x:Name="BtnIA"/>
            <Button Content="3. Archivar" HorizontalAlignment="Stretch" Padding="15" IsEnabled="False" x:Name="BtnArchivar"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text=" Núcleo Validado (Pruebas 100% OK)" Foreground="Green" HorizontalAlignment="Right"/>
    </Grid>
</Window>
